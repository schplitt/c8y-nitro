{
  "name": "c8y-nitro",
  "version": "0.5.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "description": "Lightning fast Cumulocity IoT microservice development powered by Nitro",
  "keywords": [
    "cumulocity",
    "c8y",
    "microservice",
    "nitro",
    "typescript",
    "iot",
    "docker"
  ],
  "license": "MIT",
  "author": "schplitt",
  "homepage": "https://github.com/schplitt/c8y-nitro#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/schplitt/c8y-nitro.git"
  },
  "bugs": {
    "url": "https://github.com/schplitt/c8y-nitro/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli/index.mjs",
    "./types": "./dist/types.mjs",
    "./utils": "./dist/utils.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "c8y-nitro": "./dist/cli/index.mjs"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "build:update": "tsdown --update-snapshot",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "prerelease": "eslint && tsc --noEmit && tsdown && vitest run",
    "release": "bumpp",
    "test": "vitest",
    "test:run": "vitest run",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "c12": "catalog:",
    "citty": "catalog:",
    "consola": "catalog:",
    "evlog": "catalog:",
    "itty-time": "catalog:",
    "jszip": "catalog:",
    "pathe": "catalog:",
    "pkg-types": "catalog:",
    "spinnies": "catalog:",
    "tinyexec": "catalog:"
  },
  "devDependencies": {
    "@schplitt/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "@types/spinnies": "catalog:",
    "bumpp": "catalog:",
    "changelogithub": "catalog:",
    "eslint": "catalog:",
    "memfs": "catalog:",
    "tsdown": "catalog:",
    "tsnapi": "catalog:",
    "typescript": "catalog:",
    "vitepress": "catalog:",
    "vitest": "catalog:"

  },
  "peerDependencies": {
    "@c8y/client": ">=1021",
    "nitro": "3.0.260429-beta"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}